# EventTracker Environment Variables
# Copy to .env and customize if needed
# This file is auto-generated by dev-up.sh

# Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventstracker_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Full JDBC URL
JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/eventstracker_db

# Spring Boot expects these variable names
eventstracker_JDBC_DATABASE_URL=jdbc:postgresql://localhost:5432/eventstracker_db
eventstracker_JDBC_DATABASE_USERNAME=postgres
eventstracker_JDBC_DATABASE_PASSWORD=postgres

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Application
SERVER_PORT=9081
EVENT_DOMAIN_USER=sathish
EVENT_DOMAIN_USER_PASSWORD=pass
